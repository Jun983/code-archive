@startuml break-continue
!theme plain
skinparam DefaultFontSize 13
skinparam ActivityBackgroundColor #E8EDF8
skinparam ActivityBorderColor #5C78C8
skinparam ArrowColor #333333
skinparam DiamondBackgroundColor #E8EDF8
skinparam DiamondBorderColor #5C78C8

start
:i = 0;
while (i < 10?) is (true)
  if (i == 3?) then (continue)
    note right: 이번 반복 건너뜀
  elseif (i == 6?) then (break)
    note right: 루프 즉시 종료
  else (계속)
    :출력: i;
  endif
  :i++;
endwhile (false)
stop
@enduml
